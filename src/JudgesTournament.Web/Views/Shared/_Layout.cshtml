<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - بطولة القضاة 2026</title>
    <meta name="description" content="بطولة القضاة 2026 لكرة القدم - قرية القضاة، مركز كفر صقر، محافظة الشرقية. سجل فريقك الآن!" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-brand-gradient sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
                <img src="~/images/logo.png" alt="شعار بطولة القضاة" class="navbar-brand-logo" />
                <span>بطولة القضاة 2026</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">الرئيسية</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Registration/Register">التسجيل</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer text-light mt-5">
        <div class="container">
            <div class="footer-signoff text-center mx-auto">
                <p class="footer-copyright mb-2">
                    © 2026 بطولة القضاة. جميع الحقوق محفوظة.
                </p>

                <p class="footer-developer-text mb-0">
                    تم تصميم وتطوير الموقع بواسطة
                    <span class="footer-developer-inline">
                        <span class="footer-developer-name">Loay Wael</span>
                        <span class="footer-developer-actions">
                            <a href="https://www.linkedin.com/in/loay-wael"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="footer-developer-icon-link"
                               aria-label="LinkedIn الخاص بالمطور">
                                <i class="bi bi-linkedin"></i>
                            </a>
                            <a href="https://wa.me/201097710544"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="footer-developer-icon-link"
                               aria-label="WhatsApp الخاص بالمطور">
                                <i class="bi bi-whatsapp"></i>
                            </a>
                        </span>
                    </span>
                </p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
