<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - بطولة القضاة 2026</title>
    <meta name="description" content="بطولة القضاة 2026 لكرة القدم - قرية القضاة، مركز كفر صقر، محافظة الشرقية. سجل فريقك الآن!" />

    <!-- Google Fonts - Cairo -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary-gradient sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
                <i class="bi bi-trophy-fill text-warning"></i>
                <span>بطولة القضاة 2026</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">الرئيسية</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Registration/Register">التسجيل</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="site-footer bg-dark text-light pt-4 pb-3 mt-5">
        <div class="container">
            <div class="row align-items-center gy-3">
                <!-- Location -->
                <div class="col-md-4 text-center text-md-start">
                    <p class="mb-0 small text-secondary">
                        <i class="bi bi-geo-alt-fill text-warning"></i>
                        قرية القضاة - مركز كفر صقر - محافظة الشرقية
                    </p>
                </div>
                <!-- Copyright -->
                <div class="col-md-4 text-center">
                    <p class="mb-0 small text-secondary">© 2026 بطولة القضاة. جميع الحقوق محفوظة.</p>
                </div>
                <!-- Social -->
                <div class="col-md-4 text-center text-md-end">
                    <a href="https://www.linkedin.com/in/loay-wael" target="_blank" rel="noopener noreferrer"
                       class="footer-social-link" aria-label="LinkedIn">
                        <i class="bi bi-linkedin"></i>
                    </a>
                    <a href="https://wa.me/201097710544" target="_blank" rel="noopener noreferrer"
                       class="footer-social-link" aria-label="WhatsApp">
                        <i class="bi bi-whatsapp"></i>
                    </a>
                </div>
            </div>
            <hr class="border-secondary my-3 opacity-25" />
            <p class="text-center mb-0 small text-secondary">
                تم تصميم وتطوير الموقع بواسطة <span class="text-light">Loay Wael</span>
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
