@{
    ViewData["Title"] = "الرئيسية";
}

<!-- Hero Section -->
<section class="hero-section position-relative overflow-hidden">
    <div class="hero-overlay"></div>
    <div class="container position-relative py-5">
        <div class="row align-items-center min-vh-75">
            <div class="col-lg-7 text-center text-lg-start">
                <div class="hero-badge mb-3">
                    <span class="badge bg-warning text-dark px-3 py-2 fs-6 rounded-pill">
                        <i class="bi bi-megaphone-fill"></i> باب التسجيل مفتوح الآن
                    </span>
                </div>
                <h1 class="display-3 fw-900 text-white mb-3">
                    بطولة القضاة
                    <span class="text-warning d-block">2026</span>
                </h1>
                <p class="lead text-light opacity-90 mb-4 fs-5">
                    بطولة كرة قدم تجمع أبناء قرية القضاة وأصدقائهم في منافسة رياضية مميزة.
                    <br />سارع بتسجيل فريقك الآن!
                </p>
                <a href="/Registration/Register" class="btn btn-warning btn-lg px-5 py-3 fw-bold shadow-lg hover-lift" id="btn-register-hero">
                    <i class="bi bi-pencil-square"></i> سجل فريقك الآن
                </a>
            </div>
            <div class="col-lg-5 text-center mt-4 mt-lg-0">
                <div class="trophy-icon-container">
                    <i class="bi bi-trophy-fill text-warning" style="font-size: 12rem; opacity: 0.3;"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section class="py-5 bg-light" id="about">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold fs-1"><i class="bi bi-info-circle-fill text-primary"></i> عن البطولة</h2>
            <div class="divider mx-auto"></div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm card-hover">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-primary-subtle text-primary mx-auto mb-3">
                            <i class="bi bi-geo-alt-fill fs-2"></i>
                        </div>
                        <h5 class="fw-bold">مكان الإقامة</h5>
                        <p class="text-muted">قرية القضاة<br />مركز كفر صقر<br />محافظة الشرقية</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm card-hover">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-success-subtle text-success mx-auto mb-3">
                            <i class="bi bi-cash-coin fs-2"></i>
                        </div>
                        <h5 class="fw-bold">رسوم التسجيل</h5>
                        <p class="text-muted">رسوم التسجيل المبدئي</p>
                        <p class="fs-2 fw-900 text-success">50 جنيه</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm card-hover">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-warning-subtle text-warning mx-auto mb-3">
                            <i class="bi bi-phone-fill fs-2"></i>
                        </div>
                        <h5 class="fw-bold">طريقة السداد</h5>
                        <p class="text-muted">التحويل عبر</p>
                        <p class="fs-4 fw-bold text-danger">Vodafone Cash</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Terms Section -->
<section class="py-5" id="terms">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold fs-1"><i class="bi bi-shield-check text-primary"></i> شروط وأحكام التسجيل</h2>
            <div class="divider mx-auto"></div>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <ul class="list-group list-group-flush terms-list">
                            <li class="list-group-item d-flex align-items-start gap-3 border-0 py-3">
                                <i class="bi bi-check-circle-fill text-success fs-5 mt-1"></i>
                                <span>التسجيل عبر الموقع هو تسجيل مبدئي فقط وليس تأكيد نهائي للمشاركة.</span>
                            </li>
                            <li class="list-group-item d-flex align-items-start gap-3 border-0 py-3">
                                <i class="bi bi-check-circle-fill text-success fs-5 mt-1"></i>
                                <span>يجب سداد رسوم التسجيل المبدئي (50 جنيه) عبر Vodafone Cash قبل إرسال الطلب.</span>
                            </li>
                            <li class="list-group-item d-flex align-items-start gap-3 border-0 py-3">
                                <i class="bi bi-check-circle-fill text-success fs-5 mt-1"></i>
                                <span>يجب رفع صورة واضحة لإيصال التحويل مع الطلب.</span>
                            </li>
                            <li class="list-group-item d-flex align-items-start gap-3 border-0 py-3">
                                <i class="bi bi-check-circle-fill text-success fs-5 mt-1"></i>
                                <span>ستقوم الإدارة بمراجعة الطلبات والتأكد من السداد والتواصل مع الفرق المقبولة.</span>
                            </li>
                            <li class="list-group-item d-flex align-items-start gap-3 border-0 py-3">
                                <i class="bi bi-check-circle-fill text-success fs-5 mt-1"></i>
                                <span>لكل فريق الحق في التسجيل مرة واحدة فقط.</span>
                            </li>
                            <li class="list-group-item d-flex align-items-start gap-3 border-0 py-3">
                                <i class="bi bi-check-circle-fill text-success fs-5 mt-1"></i>
                                <span>الإدارة تحتفظ بحق قبول أو رفض أي طلب تسجيل.</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 bg-primary-gradient text-white">
    <div class="container text-center">
        <h2 class="fw-bold mb-3">جاهز للمنافسة؟</h2>
        <p class="lead mb-4 opacity-90">سجل فريقك الآن وكن جزءًا من بطولة القضاة 2026</p>
        <a href="/Registration/Register" class="btn btn-warning btn-lg px-5 py-3 fw-bold shadow hover-lift" id="btn-register-cta">
            <i class="bi bi-pencil-square"></i> سجل الآن
        </a>
    </div>
</section>
