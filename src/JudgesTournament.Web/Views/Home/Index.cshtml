@{
    ViewData["Title"] = "الرئيسية";
}

<!-- ====== Hero Section ====== -->
<section class="hero-section">
    <div class="hero-bg-image" style="background-image: url('/images/stadium.jpg');"></div>
    <div class="hero-bg-overlay"></div>
    <div class="container hero-content py-5">
        <div class="row align-items-center justify-content-center text-center" style="min-height: 75vh;">
            <div class="col-lg-8">
                <img src="~/images/logo.png" alt="شعار بطولة القضاة" class="hero-logo mb-4" />
                <h1 class="hero-title mb-2">
                    بطولة القضاة <span class="gold">2026</span>
                </h1>
                <p class="hero-subtitle mb-3">منصة التسجيل المبدئي للفرق المشاركة في البطولة</p>
                <p class="hero-text mx-auto mb-4">
                    تُعد بطولة القضاة واحدة من أبرز البطولات الرياضية الجماهيرية في المنطقة، وتُقام في قرية القضاة – مركز كفر صقر – محافظة الشرقية، وسط حضور جماهيري كبير ومشاركة واسعة من الفرق من مختلف المراكز والمحافظات.
                </p>
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a href="/Registration/Register" class="btn btn-brand-gold btn-lg px-5 py-3" id="btn-hero-register">
                        <i class="bi bi-pencil-square"></i> سجل الآن
                    </a>
                    <a href="#terms" class="btn btn-brand-outline btn-lg px-4 py-3">
                        <i class="bi bi-shield-check"></i> الشروط والأحكام
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====== About the Tournament ====== -->
<section class="py-5" id="about">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h2 class="section-title"><i class="bi bi-trophy-fill text-brand-gold"></i> عن البطولة</h2>
                <div class="section-divider"></div>
                <p class="text-muted leading-relaxed">
                    تمثل بطولة القضاة حدثًا رياضيًا مميزًا يجمع بين التنافس، التنظيم، والروح الرياضية، وقد اكتسبت مكانة خاصة بفضل ما تشهده من متابعة جماهيرية واسعة وأجواء تنافسية قوية.
                </p>
                <p class="text-muted">
                    وتهدف البطولة إلى تقديم تجربة رياضية منظمة تعكس قيمة الحدث ومكانته، مع إتاحة الفرصة لمشاركة الفرق وفق ضوابط واضحة وإجراءات تسجيل معتمدة.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- ====== Tournament Location ====== -->
<section class="py-5" style="background: var(--bg-section);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h2 class="section-title"><i class="bi bi-geo-alt-fill text-brand-gold"></i> مكان إقامة البطولة</h2>
                <div class="section-divider"></div>
                <p class="text-muted">
                    تُقام البطولة في قرية القضاة التابعة لمركز كفر صقر بمحافظة الشرقية، وهي منطقة تتمتع بحضور رياضي وجماهيري مميز، ما يمنح البطولة طابعًا خاصًا ويعكس مكانتها بين البطولات الشعبية والرياضية في المنطقة.
                </p>
                <div class="info-card p-3 d-inline-flex align-items-center gap-3">
                    <div class="card-icon card-icon-gold">
                        <i class="bi bi-pin-map-fill"></i>
                    </div>
                    <div>
                        <span class="fw-bold" style="color: var(--brand-green);">قرية القضاة – مركز كفر صقر – محافظة الشرقية</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====== Registration Opening Announcement ====== -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h2 class="section-title"><i class="bi bi-megaphone-fill text-brand-gold"></i> فتح باب التسجيل</h2>
                <div class="section-divider"></div>
                <p class="text-muted">
                    تعلن اللجنة المنظمة عن فتح باب التسجيل المبدئي للفرق الراغبة في المشاركة في بطولة القضاة 2026.
                </p>
                <p class="text-muted">
                    ويتم تقديم الطلبات من خلال هذه المنصة الإلكترونية، على أن تخضع جميع الطلبات للمراجعة من قبل الإدارة قبل اعتمادها.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- ====== Registration Fee ====== -->
<section class="py-5" style="background: var(--bg-section);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h2 class="section-title"><i class="bi bi-cash-coin text-brand-gold"></i> رسوم التسجيل المبدئي</h2>
                <div class="section-divider"></div>
                <p class="text-muted mb-4">
                    تبلغ قيمة التسجيل المبدئي <strong class="text-dark">50 جنيهًا مصريًا</strong>، ويتم السداد من خلال <strong class="text-dark">Vodafone Cash</strong> وفق التعليمات الموضحة أثناء التسجيل.
                </p>
                <p class="text-muted">
                    ويُشترط رفع صورة واضحة لإيصال التحويل لاستكمال الطلب وإدخاله في مرحلة المراجعة.
                </p>
                <div class="row g-3 mt-2">
                    <div class="col-sm-4">
                        <div class="info-card p-4 text-center h-100">
                            <div class="card-icon card-icon-gold mx-auto mb-3">
                                <i class="bi bi-currency-dollar"></i>
                            </div>
                            <div class="fw-900 fs-3" style="color: var(--brand-green);">50 جنيه</div>
                            <div class="small text-muted">رسوم التسجيل المبدئي</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="info-card p-4 text-center h-100">
                            <div class="card-icon card-icon-green mx-auto mb-3">
                                <i class="bi bi-phone-fill"></i>
                            </div>
                            <div class="fw-bold" style="color: var(--brand-green);">Vodafone Cash</div>
                            <div class="small text-muted">طريقة السداد</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="info-card p-4 text-center h-100">
                            <div class="card-icon card-icon-gold mx-auto mb-3">
                                <i class="bi bi-image"></i>
                            </div>
                            <div class="fw-bold" style="color: var(--brand-green);">إيصال التحويل</div>
                            <div class="small text-muted">مطلوب رفع صورة واضحة</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====== Registration Steps ====== -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h2 class="section-title"><i class="bi bi-list-ol text-brand-gold"></i> خطوات التسجيل</h2>
                <div class="section-divider"></div>

                <div class="d-flex flex-column gap-3 mt-3">
                    <div class="info-card p-3 d-flex align-items-center gap-3">
                        <div class="step-number">1</div>
                        <span class="fw-semibold">تعبئة بيانات الفريق والمسؤول عن التسجيل</span>
                    </div>
                    <div class="info-card p-3 d-flex align-items-center gap-3">
                        <div class="step-number">2</div>
                        <span class="fw-semibold">سداد رسوم التسجيل المبدئي عبر Vodafone Cash</span>
                    </div>
                    <div class="info-card p-3 d-flex align-items-center gap-3">
                        <div class="step-number">3</div>
                        <span class="fw-semibold">رفع صورة إيصال التحويل</span>
                    </div>
                    <div class="info-card p-3 d-flex align-items-center gap-3">
                        <div class="step-number">4</div>
                        <span class="fw-semibold">انتظار مراجعة الطلب من قبل اللجنة المنظمة</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====== Terms and Conditions ====== -->
<section class="py-5" style="background: var(--bg-section);" id="terms">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h2 class="section-title"><i class="bi bi-shield-check text-brand-gold"></i> الشروط والأحكام</h2>
                <div class="section-divider"></div>

                <div class="info-card p-4">
                    <div class="term-item">
                        <i class="bi bi-check-circle-fill term-check"></i>
                        <span>التسجيل عبر الموقع هو تسجيل مبدئي فقط وليس قبولًا نهائيًا في البطولة.</span>
                    </div>
                    <div class="term-item">
                        <i class="bi bi-check-circle-fill term-check"></i>
                        <span>سداد رسوم التسجيل المبدئي لا يعني اعتماد المشاركة بشكل تلقائي.</span>
                    </div>
                    <div class="term-item">
                        <i class="bi bi-check-circle-fill term-check"></i>
                        <span>تخضع جميع الطلبات للمراجعة من قبل اللجنة المنظمة.</span>
                    </div>
                    <div class="term-item">
                        <i class="bi bi-check-circle-fill term-check"></i>
                        <span>يُشترط إدخال البيانات بشكل صحيح ورفع إثبات التحويل بصورة واضحة.</span>
                    </div>
                    <div class="term-item">
                        <i class="bi bi-check-circle-fill term-check"></i>
                        <span>لا يُسمح بتكرار التسجيل باستخدام نفس رقم الهاتف أو نفس الفريق.</span>
                    </div>
                    <div class="term-item">
                        <i class="bi bi-check-circle-fill term-check"></i>
                        <span>سيتم التواصل مع الفرق التي يتم اعتماد طلباتها لاستكمال باقي الإجراءات.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====== CTA Section ====== -->
<section class="cta-section py-5 text-white text-center">
    <div class="container position-relative" style="z-index: 2;">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <h2 class="fw-bold fs-2 mb-3">ابدأ التسجيل الآن</h2>
                <p class="mb-4 opacity-80">
                    إذا كان فريقك مستعدًا للمشاركة، يمكنكم الآن تقديم طلب التسجيل المبدئي من خلال المنصة، وسيتم مراجعة البيانات وإثبات السداد والتواصل معكم في حال استيفاء الشروط.
                </p>
                <a href="/Registration/Register" class="btn btn-brand-gold btn-lg px-5 py-3" id="btn-cta-register">
                    <i class="bi bi-pencil-square"></i> سجل الآن
                </a>
            </div>
        </div>
    </div>
</section>
