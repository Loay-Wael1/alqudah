{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=JudgesTournament;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Registration": {
    "IsOpen": true,
    "Fee": 50,
    "MaxPlayersPerTeam": 25
  },
  "Upload": {
    "MaxReceiptSizeMb": 2,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
    "ReceiptsPath": "uploads/receipts"
  },
  "RateLimiting": {
    "PermitLimit": 5,
    "WindowMinutes": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "JudgesTournament": "Information"
    }
  },
  "AllowedHosts": "*"
}
